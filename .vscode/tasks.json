		{
			"label": "list-failed-scenarios",
			"type": "shell",
			"command": "node",
			"args": [
				"-e",
				"const fs=require('fs');const p='reports/cucumber_report.json';const data=JSON.parse(fs.readFileSync(p,'utf8'));const failed=[];for(const feature of data){for(const scenario of (feature.elements||[])){const failedStep=(scenario.steps||[]).find(s=>s.result&&s.result.status==='failed');if(failedStep){failed.push({feature:feature.name,scenario:scenario.name,line:scenario.line,step:failedStep.name,error:(failedStep.result.error_message||'').split('\\n')[0]});}}}console.log('FAILED_SCENARIOS='+failed.length);failed.forEach((f,i)=>{console.log(`\\n${i+1}. FEATURE: ${f.feature}`);console.log(`   SCENARIO: ${f.scenario} (line ${f.line})`);console.log(`   STEP: ${f.step}`);console.log(`   ERROR: ${f.error}`);});"
			],
			"isBackground": false
		},
